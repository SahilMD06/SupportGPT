# ══════════════════════════════════════════════════════════════════════════════
# SupportGPT — Environment Variable Template
# Copy this file to backend/.env and fill in real values.
# NEVER commit the real .env file — it is excluded by .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-32-character-random-secret-key-here

# ─── Database (MongoDB Atlas) ─────────────────────────────────────────────────
# From MongoDB Atlas: Connect > Drivers > copy the connection string
MONGODB_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/supportgpt
MONGODB_DB_NAME=supportgpt

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local development value shown. In production, replace with your Vercel URL:
# ALLOWED_ORIGINS=["https://your-app.vercel.app"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── RAG Storage Paths ────────────────────────────────────────────────────────
# Local development defaults. On Render, point both under the persistent disk:
# FAISS_INDEX_PATH=/opt/render/project/src/data/faiss_index
# KNOWLEDGE_BASE_PATH=/opt/render/project/src/data/knowledge_base
FAISS_INDEX_PATH=./faiss_index
KNOWLEDGE_BASE_PATH=./knowledge_base

# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND — copy the line below into frontend/.env.local (separate file)
# ══════════════════════════════════════════════════════════════════════════════
# Local development value shown. In production, use your Render backend URL:
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
